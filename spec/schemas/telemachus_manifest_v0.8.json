{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://telemachus-spec.org/schemas/manifest/v0.8",
  "title": "Telemachus Dataset Manifest v0.8",
  "description": "Canonical sidecar manifest for a Telemachus Telemachus dataset. See RFC-0014.",
  "type": "object",
  "required": ["dataset_id", "schema_version", "source"],
  "additionalProperties": true,
  "properties": {
    "dataset_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_\\-]*$",
      "description": "Globally unique, lowercase, hyphen/underscore-separated identifier"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^telemachus-\\d+\\.\\d+(\\.\\d+)?$",
      "description": "Telemachus spec version this manifest targets, e.g. 'telemachus-0.8'"
    },
    "title": { "type": "string" },
    "slug": { "type": "string" },
    "country": {
      "type": "string",
      "pattern": "^[A-Z]{2}$",
      "description": "ISO 3166-1 alpha-2"
    },
    "license": { "type": "string" },
    "license_warning": { "type": "string" },
    "location": {
      "type": "object",
      "properties": {
        "city": { "type": "string" },
        "region": { "type": "string" },
        "lat_center": { "type": "number", "minimum": -90, "maximum": 90 },
        "lon_center": { "type": "number", "minimum": -180, "maximum": 180 }
      }
    },
    "period": {
      "type": "object",
      "properties": {
        "start": { "type": ["string", "null"] },
        "end": { "type": ["string", "null"], "description": "ISO-8601 or 'present'" },
        "notes": { "type": "string" }
      }
    },
    "hardware": {
      "type": "object",
      "properties": {
        "vendor": { "type": "string" },
        "model": { "type": "string" },
        "class": {
          "type": "string",
          "enum": ["commercial", "research", "consumer", "prototype", "smartphone"]
        },
        "protocol": { "type": "string" },
        "device_type_id": { "type": ["integer", "string"] },
        "notes": { "type": "string" },
        "devices": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "imei": { "type": "string" },
              "gateway_id": { "type": ["integer", "string"] },
              "serial": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "sensors": {
      "type": "object",
      "properties": {
        "gps": {
          "type": "object",
          "properties": {
            "rate_hz": { "type": ["number", "null"], "exclusiveMinimum": 0 },
            "rate_hz_declared": { "type": ["number", "null"], "exclusiveMinimum": 0 },
            "quality": { "type": "string", "enum": ["low_cost", "survey_grade", "rtk", "smartphone", "unknown"] }
          }
        },
        "accelerometer": {
          "type": "object",
          "properties": {
            "rate_hz": { "type": ["number", "null"], "exclusiveMinimum": 0 },
            "rate_native_hz": { "type": ["number", "null"], "exclusiveMinimum": 0 },
            "rate_hz_declared": { "type": ["number", "null"], "exclusiveMinimum": 0 },
            "range_g": { "type": ["number", "null"] },
            "has_gyroscope": { "type": "boolean" },
            "unit": { "type": "string" },
            "notes": { "type": "string" }
          }
        },
        "gyroscope": {
          "type": "object",
          "properties": {
            "rate_hz": { "type": ["number", "null"], "exclusiveMinimum": 0 },
            "rate_hz_declared": { "type": ["number", "null"], "exclusiveMinimum": 0 },
            "range_dps": { "type": ["number", "null"] },
            "unit": { "type": "string", "enum": ["rad/s", "deg/s"] }
          }
        },
        "magnetometer": {
          "type": "object",
          "properties": {
            "rate_hz": { "type": "number", "exclusiveMinimum": 0 },
            "unit": { "type": "string" }
          }
        },
        "obd2": {
          "type": "object",
          "properties": {
            "available": { "type": "boolean" },
            "notes": { "type": "string" }
          }
        }
      },
      "additionalProperties": true
    },
    "data_files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "format"],
        "properties": {
          "path": { "type": "string" },
          "format": { "type": "string" },
          "size_mb": { "type": "number", "minimum": 0 },
          "description": { "type": "string" },
          "location": { "type": "string" }
        }
      }
    },
    "acc_periods": {
      "type": "array",
      "description": "RFC-0013 §3.6 — accelerometer frame reference periods",
      "items": {
        "type": "object",
        "required": ["start", "end", "frame"],
        "properties": {
          "start": { "type": "string" },
          "end": { "type": "string", "description": "ISO-8601 or 'present'" },
          "frame": { "type": "string", "enum": ["raw", "compensated", "partial"] },
          "detection_method": {
            "type": "string",
            "enum": [
              "device-reported",
              "auto",
              "user",
              "empirical",
              "profile_change",
              "telto.calibration.state"
            ]
          },
          "residual_g": { "type": "number" },
          "calibration_state": { "type": ["integer", "string"] },
          "notes": { "type": "string" }
        },
        "if": { "properties": { "frame": { "const": "partial" } } },
        "then": { "required": ["residual_g"] }
      }
    },
    "carrier_state_summary": {
      "type": "object",
      "properties": {
        "mounted_driving": { "type": ["integer", "null"], "minimum": 0 },
        "mounted_idle": { "type": ["integer", "null"], "minimum": 0 },
        "unplugged": { "type": ["integer", "null"], "minimum": 0 },
        "desk": { "type": ["integer", "null"], "minimum": 0 },
        "handheld": { "type": ["integer", "null"], "minimum": 0 },
        "unknown": { "type": ["integer", "null"], "minimum": 0 }
      }
    },
    "trip_carrier_states": {
      "type": "array",
      "description": "RFC-0013 §3.7 — per-trip carrier state classification",
      "items": {
        "type": "object",
        "required": ["trip_id", "carrier_state"],
        "properties": {
          "trip_id": { "type": "string" },
          "carrier_state": {
            "type": "string",
            "enum": ["mounted_driving", "mounted_idle", "unplugged", "desk", "handheld", "unknown"]
          },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
          "detection_method": { "type": "string" },
          "signals": { "type": "object", "additionalProperties": true }
        }
      }
    },
    "volume": {
      "type": "object",
      "properties": {
        "n_devices": { "type": ["integer", "null"], "minimum": 0 },
        "n_drivers": { "type": ["integer", "null"], "minimum": 0 },
        "n_trips": { "type": ["integer", "null"], "minimum": 0 },
        "n_messages": { "type": ["integer", "null"], "minimum": 0 },
        "total_samples": { "type": ["integer", "null"], "minimum": 0 },
        "distance_km": { "type": ["number", "null"], "minimum": 0 },
        "duration_hours": { "type": ["number", "null"], "minimum": 0 }
      }
    },
    "source": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["open_external", "live", "commercial", "synthetic", "local"]
        },
        "url": { "type": "string", "format": "uri" },
        "citation": { "type": "string" },
        "doi": { "type": "string" },
        "ingestion": { "type": "string" },
        "contact": { "type": "string" },
        "campaign": { "type": "string" },
        "download_status": {
          "type": "string",
          "enum": ["not_downloaded", "partial", "complete"]
        },
        "adapter_status": {
          "type": "string",
          "enum": ["not_implemented", "draft", "production"]
        }
      },
      "additionalProperties": true
    },
    "papers_using": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["paper_id"],
        "properties": {
          "paper_id": { "type": "string" },
          "role": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["planned", "in_progress", "published"]
          },
          "notes": { "type": "string" },
          "accept_acc_periods": {
            "type": "array",
            "items": { "type": "object" }
          }
        }
      }
    },
    "config_history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string" },
          "profile": { "type": "string" },
          "changes": { "type": "object", "additionalProperties": true },
          "notes": { "type": "string" }
        }
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "labels": {
      "type": "object",
      "additionalProperties": true
    },
    "rfc_gaps": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
